---
/*
  BaseLayout
  ==========
  Every page on a themed site renders through this layout. It wires in:
    1. The active theme's design tokens (colors/fonts/spacing/radius)
    2. A small global reset that rides on top of those tokens
    3. The site-wide Header and Footer — defined ONCE here (site chrome
       that's identical on every page) so individual pages never have to
       remember to include them or keep their props in sync. This is the
       exact "fix once, applies everywhere" win the rebuild is for — on
       the old static site, header/footer markup was copy-pasted into
       every single page.

  To point this whole site at a DIFFERENT theme (e.g. spinning up RecoilOne
  from this same component library), change ONE line: the tokens import
  below. Nothing else in the codebase needs to know which theme is active.

  NOTE: site-wide nav/footer content lives below as plain constants for now
  (single-brand site). If/when this library powers multiple client sites
  from one codebase, this is the natural spot to swap in a per-theme
  site-config import instead — same "change one line" principle as tokens.
*/
import '../themes/jetavenue/tokens.css'  /* ← change this one line per brand */;
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
  jsonLd?: object | object[];
}

const {
  title,
  description = '',
  ogImage = '/images/logos/jetavenue-OG.png',
  canonicalPath,
  jsonLd,
} = Astro.props;

const siteUrl = 'https://jetavenue.net';
const canonicalUrl = canonicalPath ? `${siteUrl}${canonicalPath}` : undefined;

/* ── Site-wide Organization + LocalBusiness schema ── */
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'AirportShuttle'],
  '@id': `${siteUrl}/#organization`,
  name: 'JetAvenue',
  description: 'Mobile private jet maintenance and repair. FAA-certified technicians travel to your aircraft for line maintenance, interior repair & cleaning, and avionics support, nationwide.',
  url: siteUrl,
  logo: `${siteUrl}/images/logos/jetavenue-logo.svg`,
  image: `${siteUrl}${ogImage}`,
  telephone: '+18444805387',
  email: 'mx@jetavenue.net',
  priceRange: '$$$$',
  areaServed: {
    '@type': 'Country',
    name: 'United States',
  },
  location: [
    {
      '@type': 'Place',
      name: 'Van Nuys Airport',
      address: { '@type': 'PostalAddress', addressLocality: 'Van Nuys', addressRegion: 'CA', addressCountry: 'US' },
    },
    {
      '@type': 'Place',
      name: 'Scottsdale Airport',
      address: { '@type': 'PostalAddress', addressLocality: 'Scottsdale', addressRegion: 'AZ', addressCountry: 'US' },
    },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Mobile Private Jet Maintenance Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Line & Scheduled Maintenance' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Mobile Interior Repair & Cleaning' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Avionics Support' } },
    ],
  },
};

const allSchemas = [orgSchema, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];

const siteLogo = { src: '/images/logos/jetavenue-logo.svg', alt: 'JetAvenue' };

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const headerCta = { label: 'Work Authorization →', href: '/work-order' };

const footerPolicyLinks = [
  { label: 'Privacy Policy', href: '/privacy-policy' },
  { label: 'Terms & Conditions', href: '/terms' },
  { label: 'Contact', href: '/contact' },
];

const footerSocial = {
  facebook: '',
  instagram: '',
  pinterest: '',
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="JetAvenue" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(allSchemas)} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <Header logo={siteLogo} navLinks={navLinks} cta={headerCta} />
    <slot />
    <Footer
      logo={{ src: '/images/logos/jetavenue-logo.svg', alt: 'JetAvenue: Mobile Private Jet Repair' }}
      tagline="Mobile Private Jet Repair & Maintenance, Nationwide"
      policyLinks={footerPolicyLinks}
      social={footerSocial}
      legalName="JetAvenue"
      address=""
    />
  </body>
</html>
