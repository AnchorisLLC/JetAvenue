---
/*
  Footer — full site footer
  =========================
  Astro-component version of the old `footer` HTML snippet. Appears on
  every page. Pattern matches Hero.astro / Header.astro:
    - Brand/content (logo, tagline, links, legal text) comes in as PROPS
    - Styling lives in the scoped <style> block, reads ONLY from theme tokens
    - Subscribe form submit-guard lives in the scoped <script> block

  NOTE: the live site's footer legal line currently reads
  "© 2026 PrintOnThis.com..." — a copy-paste leftover from a sibling brand.
  This component defaults `legalName` to "NetSnapz.com" (corrected), and
  takes it as a prop so any site built on this library can set its own.

  Social links and payment icons are treated as site CHROME — the SVG
  marks rarely change — but the hrefs for social are still props since
  those are genuinely brand-specific.

  Usage:
    <Footer
      logo={{ src: "/images/logos/netsnapz-logo.svg", alt: "NetSnapz snap-on net banners" }}
      tagline="The Original Snap-On Net Banners for Every Sport"
      policyLinks={[
        { label: "Privacy", href: "/privacy-policy" },
        { label: "Returns", href: "/return-policy" },
        { label: "Shipping", href: "/shipping-policy" },
        { label: "Contact", href: "/contact" },
      ]}
      social={{
        facebook: "https://facebook.com/printonthis",
        instagram: "https://instagram.com/printonthis",
        pinterest: "https://pinterest.com/printonthis",
      }}
      legalName="NetSnapz.com"
      address="1702 Willow Creek Rd Ste A, Prescott, CA 86301"
    />
*/

interface PolicyLink { label: string; href: string }
interface LogoProps { src: string; alt: string }
interface SocialLinks { facebook?: string; instagram?: string; pinterest?: string }

interface Props {
  logo: LogoProps;
  tagline: string;
  policyLinks: PolicyLink[];
  social?: SocialLinks;
  legalName?: string;
  address?: string;
  year?: number;
}

const {
  logo,
  tagline,
  policyLinks,
  social = {},
  legalName = 'NetSnapz.com',
  address = '',
  year = new Date().getFullYear(),
} = Astro.props;
---

<footer class="footer">
  <div class="container footer-inner">

    <!-- Logo + tagline -->
    <div class="footer-brand">
      <img src={logo.src} alt={logo.alt} class="logo-footer" />
      <p class="footer-tagline">{tagline}</p>
    </div>

    <!-- Policy links -->
    <nav class="footer-links">
      {policyLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>

    <!-- Subscribe + Social row -->
    <div class="footer-mid-row">
<div class="footer-social">
        {social.facebook && (
          <a href={social.facebook} target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        )}
        {social.instagram && (
          <a href={social.instagram} target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        )}
        {social.pinterest && (
          <a href={social.pinterest} target="_blank" rel="noopener" aria-label="Pinterest">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
          </a>
        )}
      </div>
    </div>

    <!-- Payment icons -->
    <div class="footer-payments">
      <svg class="payment-icon" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="American Express"><rect width="38" height="24" rx="4" fill="#2E77BC"/><text x="19" y="16" text-anchor="middle" font-family="Arial,sans-serif" font-size="8" font-weight="700" fill="white" letter-spacing="0.5">AMEX</text></svg>
      <svg class="payment-icon" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Apple Pay"><rect width="38" height="24" rx="4" fill="#000"/><text x="19" y="15.5" text-anchor="middle" font-family="-apple-system,BlinkMacSystemFont,sans-serif" font-size="7.5" font-weight="500" fill="white"> Pay</text><path d="M10.8 8.4c.5-.6.8-1.4.7-2.2-.7.1-1.6.5-2.1 1.1-.5.5-.8 1.3-.7 2.1.8.1 1.6-.4 2.1-1z" fill="white"/><path d="M11.5 9.5c-1.2-.1-2.2.7-2.7.7-.6 0-1.4-.7-2.3-.6-1.2.1-2.3.7-2.9 1.7-1.2 2.1-.3 5.2.9 6.9.6.9 1.3 1.8 2.2 1.8.9 0 1.2-.6 2.3-.6 1.1 0 1.4.6 2.3.5.9 0 1.5-.8 2.1-1.7.7-.9.9-1.8 1-1.8-.1 0-1.8-.7-1.9-2.8 0-1.8 1.4-2.6 1.5-2.7-.9-1.3-2.2-1.4-2.5-1.4z" fill="white" transform="scale(0.55) translate(3,2)"/></svg>
      <svg class="payment-icon" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Diners Club"><rect width="38" height="24" rx="4" fill="white" stroke="#e0e0e0" stroke-width="1"/><circle cx="15" cy="12" r="6" fill="none" stroke="#004A97" stroke-width="1.5"/><circle cx="23" cy="12" r="6" fill="none" stroke="#004A97" stroke-width="1.5"/></svg>
      <svg class="payment-icon" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Discover"><rect width="38" height="24" rx="4" fill="white" stroke="#e0e0e0" stroke-width="1"/><circle cx="27" cy="12" r="7" fill="#F76F20"/><text x="5" y="15.5" font-family="Arial,sans-serif" font-size="6" font-weight="700" fill="#231F20" letter-spacing="0.2">discover</text></svg>
      <svg class="payment-icon" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Google Pay"><rect width="38" height="24" rx="4" fill="white" stroke="#e0e0e0" stroke-width="1"/><text x="7" y="15.5" font-family="Arial,sans-serif" font-size="8" font-weight="500" fill="#5F6368">G</text><text x="14" y="15.5" font-family="Arial,sans-serif" font-size="8" font-weight="500" fill="#5F6368">Pay</text><text x="7" y="15.5" font-family="Arial,sans-serif" font-size="8" font-weight="700" fill="#4285F4">G</text></svg>
      <svg class="payment-icon" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Mastercard"><rect width="38" height="24" rx="4" fill="white" stroke="#e0e0e0" stroke-width="1"/><circle cx="15" cy="12" r="7" fill="#EB001B"/><circle cx="23" cy="12" r="7" fill="#F79E1B"/><path d="M19 6.8a7 7 0 0 1 0 10.4A7 7 0 0 1 19 6.8z" fill="#FF5F00"/></svg>
      <svg class="payment-icon" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Shop Pay"><rect width="38" height="24" rx="4" fill="#5A31F4"/><text x="19" y="15.5" text-anchor="middle" font-family="Arial,sans-serif" font-size="6.5" font-weight="700" fill="white" letter-spacing="0.3">Shop Pay</text></svg>
      <svg class="payment-icon" viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Visa"><rect width="38" height="24" rx="4" fill="white" stroke="#e0e0e0" stroke-width="1"/><text x="19" y="16" text-anchor="middle" font-family="Arial,sans-serif" font-size="11" font-weight="700" fill="#1A1F71" letter-spacing="1" font-style="italic">VISA</text></svg>
    </div>

    <!-- Copyright -->
    <div class="footer-legal">
      &copy; {year} {legalName}. All rights reserved.
      {address && <><br />{address}</>}
    </div>

  </div>
</footer>

<style>
  .footer { background: var(--color-surface-alt); border-top: 1px solid var(--color-border); padding: var(--space-xl) 0 28px; }
  .footer-inner {
    display: flex; flex-direction: column; align-items: center;
    gap: var(--space-md); text-align: center;
  }
  .footer-brand { display: flex; flex-direction: column; align-items: center; gap: 10px; }
  .logo-footer { width: 205px; height: auto; }
  .footer-tagline { font-size: 12px; color: var(--color-body); margin: 0; }
  .footer-links {
    display: flex; gap: var(--space-md); flex-wrap: wrap; justify-content: center; align-items: center;padding:30px 0;
  }
  .footer-links a { color: var(--color-body); text-decoration: none; font-size: 13px; }
  .footer-links a:hover { color: var(--color-ink); }
  .footer-mid-row {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; gap: var(--space-md);
  }
  .footer-subscribe { display: flex; flex-direction: column; align-items: flex-start; gap: 12px; }
  .footer-subscribe-label { font-size: 14px; font-weight: 500; color: var(--color-ink); margin: 0; }
  .footer-email-form { display: flex; border: 1px solid var(--color-border); border-radius: 4px; overflow: hidden; }
  .footer-email-input {
    padding: 10px 14px; font-size: 13px; border: none; outline: none;
    width: 240px; background: var(--color-surface);
  }
  .footer-email-btn {
    padding: 10px 14px; background: var(--color-surface); border: none;
    border-left: 1px solid var(--color-border); cursor: pointer; font-size: 16px; color: var(--color-ink);
  }
  .footer-email-btn:hover { background: var(--color-surface-alt); }
  .footer-social { display: flex; gap: var(--space-sm); align-items: center; }
  .footer-social a { color: var(--color-ink); text-decoration: none; }
  .footer-social a:hover { color: var(--color-accent); }
  /*.footer-payments { display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; align-items: center; }
  .payment-icon { width: 38px; height: 24px; display: inline-block; }*/ 
  .footer-legal { font-size: 11px; color: var(--color-body); line-height: 1.8; }

  @media (max-width: 900px) {
    .footer-email-input { width: 180px; }
    .footer-mid-row     { flex-direction: column; align-items: center; }
    .footer-subscribe   { align-items: center; }
  }
</style>

<script>
  // Subscribe-form submit guard — scoped to this component. The live site
  // currently has no email backend wired to this form (onsubmit="return
  // false" placeholder); this preserves that behavior until a provider
  // (e.g. Klaviyo/Mailchimp/Formspree) is chosen, at which point this
  // handler gets replaced with a real fetch() to that endpoint.
  document.querySelectorAll<HTMLFormElement>('[data-subscribe-form]').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      // TODO: wire to email provider once chosen.
    });
  });
</script>
