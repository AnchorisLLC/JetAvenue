---
/*
  ServiceSlider
  =============
  Desktop: full-bleed image slider, text overlay bottom-left, dot nav.
  Mobile: stacked photo + color-panel cards (same data, different layout).

  Each slide:
    title       — card/slide headline
    sub         — one-line descriptor
    href        — "Learn More" link target
    img         — photo path
    imgAlt      — alt text
    panelColor  — color-matched panel bg (mobile) / overlay tint (desktop)
*/

interface Slide {
  title: string;
  sub: string;
  href: string;
  img: string;
  imgAlt: string;
  panelColor: string;
}

interface Props {
  slides: Slide[];
}

const { slides } = Astro.props;
---

<!-- ── MOBILE: stacked cards ── -->
<div class="mobile-stack">
  {slides.map((s) => (
    <div class="stack-card">
      <div class="stack-img-wrap">
        <img src={s.img} alt={s.imgAlt} loading="lazy" />
      </div>
      <div class="stack-panel" style={`background:${s.panelColor}`}>
        <h2>{s.title}</h2>
        <p>{s.sub}</p>
        <a href={s.href} class="stack-btn">Learn More</a>
      </div>
    </div>
  ))}
</div>

<!-- ── DESKTOP: full-bleed slider ── -->
<div class="slider" data-slider>
  <div class="slider-track" data-track>
    {slides.map((s, i) => (
      <div class={`slide${i === 0 ? ' is-active' : ''}`} data-slide>
        <img src={s.img} alt={s.imgAlt} class="slide-img" />
        <div class="slide-overlay" style={`--panel:${s.panelColor}`}></div>
        <div class="slide-content">
          <h2 class="slide-title">{s.title}</h2>
          <p class="slide-sub">{s.sub}</p>
          <a href={s.href} class="slide-btn">Learn More</a>
        </div>
      </div>
    ))}
  </div>

  <!-- Dot nav -->
  <div class="slider-dots" data-dots>
    {slides.map((_, i) => (
      <button
        class={`dot${i === 0 ? ' is-active' : ''}`}
        data-dot={i}
        aria-label={`Go to slide ${i + 1}`}
      ></button>
    ))}
  </div>

  <!-- Arrows -->
  <button class="slider-arrow slider-prev" data-prev aria-label="Previous">&#8249;</button>
  <button class="slider-arrow slider-next" data-next aria-label="Next">&#8250;</button>
</div>

<style>
  /* ══ MOBILE STACK (default) ══ */
  .slider { display: none; }

  .mobile-stack { display: flex; flex-direction: column; }

  .stack-card { display: flex; flex-direction: column; }

  .stack-img-wrap {
    width: 100%; aspect-ratio: 4/3; overflow: hidden; background: #ccc;
  }
  .stack-img-wrap img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }

  .stack-panel {
    padding: 32px 28px 36px; text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 12px;
    border-radius: 0 0 3px 3px;
  }
  .stack-panel h2 {
    font-family: var(--font-heading); font-size: 22px; font-weight: 700;
    color: #fff; margin: 0; letter-spacing: 0.01em;
  }
  .stack-panel p {
    font-family: var(--font-body); font-size: 15px;
    color: rgba(255,255,255,0.85); margin: 0; max-width: 380px; line-height: 1.5;
  }
  .stack-btn {
    display: inline-block; margin-top: 6px; padding: 10px 28px;
    border: 2px solid #fff; color: #fff;
    font-family: var(--font-heading); font-size: 14px; font-weight: 600;
    letter-spacing: 0.04em; text-decoration: none; background: transparent;
    border-radius: 3px; transition: background 0.18s, color 0.18s;
  }
  .stack-btn:hover { background: #fff; color: #111; }

  /* ══ DESKTOP SLIDER ══ */
  @media (min-width: 900px) {
    .mobile-stack { display: none; }
    .slider {
      display: block; position: relative; overflow: hidden;
      height: 72vh; min-height: 480px; max-height: 720px;
      border-radius: 3px;
    }

    .slider-track { width: 100%; height: 100%; position: relative; }

    .slide {
      position: absolute; inset: 0;
      opacity: 0; transition: opacity 0.55s ease; pointer-events: none;
    }
    .slide.is-active { opacity: 1; pointer-events: auto; }

    .slide-img {
      width: 100%; height: 100%; object-fit: cover; display: block;
    }

    /* gradient overlay — darkens bottom so text reads */
    .slide-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(
        to top,
        color-mix(in srgb, var(--panel) 80%, transparent) 0%,
        color-mix(in srgb, var(--panel) 30%, transparent) 35%,
        transparent 65%
      );
    }

    .slide-content {
      position: absolute; bottom: 60px; left: 50%; transform: translateX(-50%);
      max-width: 560px; width: 100%; text-align: center;
      display: flex; flex-direction: column; align-items: center;
    }
    .slide-title {
      font-family: var(--font-heading); font-size: clamp(26px, 3vw, 36px); font-weight: 700;
      color: #fff; margin: 0 0 10px; letter-spacing: 0.01em; line-height: 1.15;
      text-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }
    .slide-sub {
      font-family: var(--font-body); font-size: 16px;
      color: rgba(255,255,255,0.9); margin: 0 0 20px; line-height: 1.5;
    }
    .slide-btn {
      display: inline-block; padding: 11px 30px;
      border: 2px solid #fff; color: #fff;
      font-family: var(--font-heading); font-size: 14px; font-weight: 600;
      letter-spacing: 0.06em; text-decoration: none; background: transparent;
      border-radius: 3px; transition: background 0.18s, color 0.18s;
    }
    .slide-btn:hover { background: #fff; color: #111; }

    /* Dot nav */
    .slider-dots {
      position: absolute; bottom: 24px; left: 50%;
      transform: translateX(-50%);
      display: flex; gap: 8px; z-index: 10;
    }
    .dot {
      width: 10px; height: 10px; border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.7); background: transparent;
      cursor: pointer; padding: 0; transition: background 0.18s, border-color 0.18s;
    }
    .dot.is-active { background: #fff; border-color: #fff; }

    /* Arrows */
    .slider-arrow {
      position: absolute; top: 50%; transform: translateY(-50%);
      background: rgba(0,0,0,0.28); border: none; color: #fff;
      font-size: 36px; line-height: 1; width: 48px; height: 48px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; z-index: 10; border-radius: 3px;
      transition: background 0.18s;
    }
    .slider-arrow:hover { background: rgba(0,0,0,0.55); }
    .slider-prev { left: 16px; }
    .slider-next { right: 16px; }
  }
</style>

<script>
  const slider = document.querySelector<HTMLElement>('[data-slider]');
  if (slider) {
    const slides = Array.from(slider.querySelectorAll<HTMLElement>('[data-slide]'));
    const dots   = Array.from(slider.querySelectorAll<HTMLElement>('[data-dot]'));
    let current  = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(n: number) {
      slides[current].classList.remove('is-active');
      dots[current].classList.remove('is-active');
      current = (n + slides.length) % slides.length;
      slides[current].classList.add('is-active');
      dots[current].classList.add('is-active');
    }

    function startAuto() {
      timer = setInterval(() => goTo(current + 1), 5000);
    }

    function resetAuto() {
      clearInterval(timer);
      startAuto();
    }

    dots.forEach((dot) => dot.addEventListener('click', () => {
      goTo(Number(dot.dataset.dot));
      resetAuto();
    }));

    slider.querySelector('[data-prev]')?.addEventListener('click', () => { goTo(current - 1); resetAuto(); });
    slider.querySelector('[data-next]')?.addEventListener('click', () => { goTo(current + 1); resetAuto(); });

    slider.addEventListener('mouseenter', () => clearInterval(timer));
    slider.addEventListener('mouseleave', startAuto);

    startAuto();
  }
</script>
