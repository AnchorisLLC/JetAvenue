---
interface Props {
  heading?: string;
  subhead?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  note?: string;
}

const {
  heading    = "Ready to Schedule Service?",
  subhead    = "Our technicians come to your aircraft. Tell us where it is.",
  primaryLabel   = "Submit Work Order →",
  primaryHref    = "/work-order",
  secondaryLabel = "Contact Us",
  secondaryHref  = "/contact",
  note = "Response within one business day · VNY · SDL · Nationwide",
} = Astro.props;
---

<section class="cta-strip">
  <div class="cta-inner">
    <h2>{heading}</h2>
    <p>{subhead}</p>
    <div class="cta-buttons">
      <a href={secondaryHref} class="cta-btn-outline">{secondaryLabel}</a>
      <a href={primaryHref} class="cta-btn-primary">{primaryLabel}</a>
    </div>
    <p class="cta-note">{note}</p>
  </div>
</section>

<style>
  .cta-strip {
    background: var(--color-ink);
    text-align: center;
    padding: 64px var(--space-md);
  }
  .cta-inner {
    max-width: 640px;
    margin: 0 auto;
  }
  .cta-inner h2 {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3.5vw, 36px);
    font-weight: 800;
    color: #fff;
    margin: 0 0 14px;
    letter-spacing: -0.02em;
  }
  .cta-inner p {
    font-family: var(--font-body);
    font-size: 16px;
    color: rgba(255,255,255,0.72);
    margin: 0 0 32px;
    line-height: 1.6;
  }
  .cta-buttons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }
  .cta-btn-primary {
    display: inline-block;
    padding: 13px 28px;
    background: var(--color-brand);
    color: #fff;
    border-radius: 3px;
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: background 0.18s;
  }
  .cta-btn-primary:hover { background: var(--color-brand-dark); }
  .cta-btn-outline {
    display: inline-block;
    padding: 13px 28px;
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255,255,255,0.35);
    border-radius: 3px;
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: border-color 0.18s;
  }
  .cta-btn-outline:hover { border-color: #fff; }
  .cta-note {
    font-family: var(--font-body);
    font-size: 12px;
    color: rgba(255,255,255,0.45);
    margin: 0;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
</style>
