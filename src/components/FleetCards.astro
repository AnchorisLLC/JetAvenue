---
interface FleetItem {
  name: string;
  models: string;
  img: string;
  imgAlt: string;
  logo?: string;
}

interface Props {
  items: FleetItem[];
}

const { items } = Astro.props;
---

<section class="fleet-section">
  <div class="fleet-container">
    <p class="eyebrow">FLEET COVERAGE</p>
    <h2>Airframes We Support</h2>

    <div class="fleet-list">
      {items.map((item, i) => (
        <div class={`fleet-card${i % 2 === 1 ? ' fleet-card--reverse' : ''}`}>
          <div class="fleet-img-wrap">
            <img src={item.img} alt={item.imgAlt} loading="lazy" class={item.img === item.logo ? 'is-logo' : ''} />
          </div>
          <div class="fleet-info">
            <h3>{item.name}</h3>
            <p class="fleet-models">{item.models}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .fleet-section {
    padding: 80px 0 96px;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }
  .fleet-container {
    max-width: 1080px; margin: 0 auto; padding: 0 var(--space-md);
  }
  .eyebrow {
    font-family: var(--font-heading); font-size: 11px; font-weight: 700;
    letter-spacing: 0.2em; color: var(--color-brand); text-transform: uppercase;
    margin: 0 0 12px;
  }
  h2 {
    font-family: var(--font-heading); font-size: clamp(26px, 3.5vw, 38px);
    font-weight: 800; color: var(--color-ink); margin: 0 0 56px;
    letter-spacing: -0.02em;
  }

  .fleet-list { display: flex; flex-direction: column; gap: 24px; }

  .fleet-card {
    display: grid;
    grid-template-columns: 1fr;
    border-radius: 3px; overflow: hidden;
    border: 1.5px solid var(--color-border);
    background: #fff;
  }

  .fleet-img-wrap {
    aspect-ratio: 16/9; overflow: hidden;
    background: #f0f0f0;
    display: flex; align-items: center; justify-content: center;
  }
  .fleet-img-wrap img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.4s ease;
  }
  .fleet-img-wrap img.is-logo {
    width: auto; height: 50%;
    max-width: 60%;
    object-fit: contain;
    opacity: 0.35; filter: grayscale(1);
  }
  .fleet-card:hover .fleet-img-wrap img:not(.is-logo) { transform: scale(1.03); }

  .fleet-info {
    padding: 28px 28px 32px;
    display: flex; flex-direction: column; justify-content: center;
  }
  .fleet-info h3 {
    font-family: var(--font-heading); font-size: 22px; font-weight: 800;
    color: var(--color-ink); margin: 0 0 12px; letter-spacing: -0.01em;
  }
  .fleet-models {
    font-family: var(--font-body); font-size: 15px; color: var(--color-body);
    line-height: 1.75; margin: 0;
  }

  @media (min-width: 700px) {
    .fleet-card {
      grid-template-columns: 1fr 1fr;
      aspect-ratio: unset;
    }
    .fleet-img-wrap { aspect-ratio: unset; min-height: 280px; }
    .fleet-card--reverse .fleet-img-wrap { order: 2; }
    .fleet-card--reverse .fleet-info { order: 1; }
    .fleet-info { padding: 40px 44px; }
  }

  @media (min-width: 1000px) {
    .fleet-card { grid-template-columns: 3fr 2fr; }
    .fleet-card--reverse { grid-template-columns: 2fr 3fr; }
    .fleet-img-wrap { min-height: 320px; }
  }
</style>
