---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact JetAvenue: Request Mobile Jet Maintenance"
  description="Request a free assessment or reach out about mobile private jet maintenance. JetAvenue serves VNY, SDL, and nationwide. Call (844) 480-5387."
  canonicalPath="/contact"
>

  <section class="contact-hero">
    <p class="eyebrow">GET IN TOUCH</p>
    <h1>Request a Free Assessment</h1>
    <p>Tell us about your aircraft and we'll get back to you within one business day.</p>
  </section>

  <section class="contact-body">
    <div class="contact-container">
      <div class="contact-grid">

        <!-- Info column -->
        <div class="contact-info">
          <p class="eyebrow">LET'S TALK</p>
          <h2>We Come to Your Aircraft</h2>
          <p class="contact-intro">Whether you need routine line maintenance, interior repair, avionics support, or post-flight cleaning, our certified technicians travel to you. No ferry flights. No hangar wait. Just expert service on your schedule.</p>

          <ul class="contact-details">
            <li>
              <span class="contact-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.41 2 2 0 0 1 3.58 1.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 15.92z"/></svg>
              </span>
              <span><a href="tel:8444805387">(844) 480-5387</a></span>
            </li>
            <li>
              <span class="contact-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
              <a href="mailto:mx@jetavenue.net">mx@jetavenue.net</a>
            </li>
            <li>
              <span class="contact-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <span>Los Angeles (VNY) · Arizona (SDL) · Nationwide</span>
            </li>
          </ul>

          <div class="service-tags-wrap">
            <p class="tags-label">Services</p>
            <div class="service-tags">
              <span class="service-tag">Line Maintenance</span>
              <span class="service-tag">Interior Repair</span>
              <span class="service-tag">Avionics</span>
              <span class="service-tag">Cleaning</span>
            </div>
          </div>
        </div>

        <!-- Form card -->
        <div class="form-card">
          <h3>Send Us a Message</h3>
          <p class="form-sub">We respond within one business day.</p>
          <form id="contact-form" action="https://formspree.io/f/mjgdrvzg" method="POST" novalidate>
            <div class="cf-row">
              <div class="cf-group">
                <label for="cf-name">Your Name</label>
                <input type="text" id="cf-name" name="name" placeholder="John Smith" required />
              </div>
              <div class="cf-group">
                <label for="cf-email">Email Address</label>
                <input type="email" id="cf-email" name="email" placeholder="john@example.com" required />
              </div>
            </div>
            <div class="cf-row">
              <div class="cf-group">
                <label for="cf-phone">Phone (optional)</label>
                <input type="tel" id="cf-phone" name="phone" placeholder="(844) 555-0100" />
              </div>
              <div class="cf-group">
                <label for="cf-service">Service Needed</label>
                <select id="cf-service" name="service">
                  <option value="">Select one…</option>
                  <option>Line &amp; Schedule Maintenance</option>
                  <option>Mobile Interior Repair</option>
                  <option>Avionics Support</option>
                  <option>Cleaning</option>
                  <option>Multiple Services</option>
                  <option>Not Sure Yet</option>
                </select>
              </div>
            </div>
            <div class="cf-group">
              <label for="cf-aircraft">Aircraft Make &amp; Model (optional)</label>
              <input type="text" id="cf-aircraft" name="aircraft" placeholder="e.g. Gulfstream G550" />
            </div>
            <div class="cf-group">
              <label for="cf-message">Tell us about your needs</label>
              <textarea id="cf-message" name="message" rows="4" placeholder="Location, aircraft, service needed, timeline…"></textarea>
            </div>
            <input type="hidden" name="_replyto" id="_replyto" />
            <button type="submit" class="cf-btn">Send Message →</button>
            <div class="cf-success" style="display:none;">Thanks, we'll be in touch within one business day.</div>
            <div class="cf-error" style="display:none;">Something went wrong. Please email us at <a href="mailto:mx@jetavenue.net">mx@jetavenue.net</a>.</div>
          </form>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .contact-hero {
    background: var(--color-surface);
    text-align: center;
    padding: var(--space-xl) var(--space-md) var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }
  .eyebrow {
    font-family: var(--font-heading); font-size: 11px; font-weight: 700;
    letter-spacing: 0.2em; color: var(--color-brand); text-transform: uppercase;
    margin: 0 0 12px;
  }
  .contact-hero h1 {
    font-family: var(--font-heading); font-size: clamp(28px, 4vw, 46px);
    font-weight: 800; color: var(--color-ink); margin: 0 0 14px; letter-spacing: -0.02em;
  }
  .contact-hero p {
    font-family: var(--font-body); font-size: 16px; color: var(--color-body);
    max-width: 500px; margin: 0 auto; line-height: 1.6;
  }

  .contact-body { padding: 64px 0 80px; }
  .contact-container { max-width: 1080px; margin: 0 auto; padding: 0 var(--space-md); }

  .contact-grid {
    display: grid; grid-template-columns: 1fr;
    gap: 48px; align-items: start;
  }

  /* Info */
  .contact-info h2 {
    font-family: var(--font-heading); font-size: 26px; font-weight: 800;
    color: var(--color-ink); margin: 8px 0 14px; letter-spacing: -0.01em;
  }
  .contact-intro {
    font-family: var(--font-body); font-size: 15px; color: var(--color-body);
    line-height: 1.75; margin: 0 0 28px;
  }
  .contact-details {
    list-style: none; padding: 0; margin: 0 0 28px;
    display: flex; flex-direction: column; gap: 16px;
  }
  .contact-details li {
    display: flex; align-items: flex-start; gap: 14px;
    font-family: var(--font-body); font-size: 15px; color: var(--color-body);
  }
  .contact-icon {
    width: 36px; height: 36px; border-radius: 50%; flex: 0 0 36px;
    background: #FFF0E6; border: 1.5px solid rgba(243,111,33,0.25);
    display: flex; align-items: center; justify-content: center;
  }
  .contact-icon svg { width: 16px; height: 16px; stroke: var(--color-brand); }
  .contact-details a { color: var(--color-brand); text-decoration: none; font-weight: 600; }
  .contact-details a:hover { text-decoration: underline; }

  .tags-label {
    font-family: var(--font-heading); font-size: 11px; font-weight: 700;
    letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-body);
    margin: 0 0 12px;
  }
  .service-tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .service-tag {
    display: inline-block; padding: 6px 14px; border-radius: 3px;
    background: #FFF0E6; color: var(--color-brand);
    font-family: var(--font-heading); font-size: 12px; font-weight: 700;
    letter-spacing: 0.04em;
  }

  /* Form card */
  .form-card {
    background: #fafafa; border: 1px solid var(--color-border);
    border-radius: 6px; padding: 36px 32px;
  }
  .form-card h3 {
    font-family: var(--font-heading); font-size: 20px; font-weight: 800;
    color: var(--color-ink); margin: 0 0 6px;
  }
  .form-sub {
    font-family: var(--font-body); font-size: 14px; color: var(--color-body);
    margin: 0 0 24px;
  }
  .cf-group { margin-bottom: 18px; }
  .cf-group label {
    display: block; font-family: var(--font-heading); font-size: 11px;
    font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--color-ink); margin-bottom: 6px;
  }
  .cf-group input,
  .cf-group select,
  .cf-group textarea {
    width: 100%; padding: 11px 14px;
    border: 1.5px solid var(--color-border); border-radius: 3px;
    font-family: var(--font-body); font-size: 14px;
    color: var(--color-ink); background: #fff;
    transition: border-color 0.15s; outline: none;
  }
  .cf-group input:focus,
  .cf-group select:focus,
  .cf-group textarea:focus { border-color: var(--color-brand); }
  .cf-group textarea { resize: vertical; }
  .cf-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

  .cf-btn {
    width: 100%; padding: 14px;
    background: var(--color-brand); color: #fff; border: none; border-radius: 3px;
    font-family: var(--font-heading); font-size: 15px; font-weight: 700;
    letter-spacing: 0.04em; cursor: pointer; transition: background 0.18s; margin-top: 4px;
  }
  .cf-btn:hover { background: var(--color-brand-dark); }
  .cf-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .cf-success {
    margin-top: 14px; padding: 12px 16px;
    background: #f0fdf4; border: 1px solid #86efac;
    border-radius: 3px; color: #166534;
    font-family: var(--font-body); font-size: 14px; font-weight: 600;
  }
  .cf-error {
    margin-top: 14px; padding: 12px 16px;
    background: #fff5f5; border: 1px solid #fca5a5;
    border-radius: 3px; color: #991b1b;
    font-family: var(--font-body); font-size: 14px;
  }
  .cf-error a { color: var(--color-brand); }

  @media (min-width: 860px) {
    .contact-grid { grid-template-columns: 1fr 1.3fr; gap: 60px; }
    .form-card { padding: 40px 36px; }
  }
  @media (max-width: 600px) {
    .cf-row { grid-template-columns: 1fr; gap: 0; }
    .form-card { padding: 28px 20px; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', function(e) {
    (document.getElementById('_replyto') as HTMLInputElement).value =
      (document.getElementById('cf-email') as HTMLInputElement).value;
    e.preventDefault();
    const btn = form.querySelector('.cf-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending…';
    fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    }).then(res => {
      if (res.ok) {
        form.reset();
        (form.querySelector('.cf-success') as HTMLElement).style.display = 'block';
        (form.querySelector('.cf-error') as HTMLElement).style.display = 'none';
        btn.style.display = 'none';
      } else { throw new Error(); }
    }).catch(() => {
      (form.querySelector('.cf-error') as HTMLElement).style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Send Message →';
    });
  });
</script>
