---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceSlider from '../components/ServiceSlider.astro';
import FAQ from '../components/FAQ.astro';
import FleetCards from '../components/FleetCards.astro';
import CtaStrip from '../components/CtaStrip.astro';
import { faqItems } from '../data/faq';

const fleetItems = [
  {
    name: 'Gulfstream',
    models: 'GIV · G450 · GV · G550 · G650 · G500 · G600',
    img: '/images/fleet/gulfstream-logo.svg',
    imgAlt: 'Gulfstream G650 private jet on the ramp, JetAvenue mobile maintenance',
    logo: '/images/fleet/gulfstream-logo.svg',
  },
  {
    name: 'Bombardier',
    models: 'Challenger 300 · 350 · 3500 · 604 · 605 · 650 · Global Express · XRS · 5000 · 6000 · 7500 · CRJ 800',
    img: '/images/fleet/bombardier-logo.svg',
    imgAlt: 'Bombardier Challenger 650 private jet, JetAvenue certified maintenance',
    logo: '/images/fleet/bombardier-logo.svg',
  },
  {
    name: 'Dassault',
    models: 'DA50 · Falcon 900 · 2000 · 2000 EX EASY · 7X',
    img: '/images/fleet/dassault-logo.svg',
    imgAlt: 'Dassault Falcon 7X private jet, mobile avionics and interior repair',
    logo: '/images/fleet/dassault-logo.svg',
  },
  {
    name: 'Embraer',
    models: 'ERJ135 · ERJ145 · Legacy 600 · Legacy 650 · E-Jet 190',
    img: '/images/fleet/embraer-logo.svg',
    imgAlt: 'Embraer Legacy 650 private jet, mobile line maintenance by JetAvenue',
    logo: '/images/fleet/embraer-logo.svg',
  },
  {
    name: 'Cessna',
    models: 'Citation 560XL · 560XLS · CIT X · 680 · 680A',
    img: '/images/fleet/cessna-logo.svg',
    imgAlt: 'Cessna Citation CJ private jet, scheduled maintenance and interior cleaning',
    logo: '/images/fleet/cessna-logo.svg',
  },
];

const slides = [
  {
    title: 'Line & Scheduled Maintenance',
    sub: '24/7 on-call aircraft support to keep operations moving',
    href: '/services#line-maintenance',
    img: '/images/heros/home-hero-1.jpg',
    imgAlt: 'FAA-certified technician performing line maintenance on a private jet at the ramp',
    panelColor: '#3A5A8C',
  },
  {
    title: 'Interior Cleaning & Repair',
    sub: 'On-site cabin interior repairs without downtime',
    href: '/services#interior',
    img: '/images/heros/home-hero-2.webp',
    imgAlt: 'JetAvenue technician repairing leather seating in a private jet cabin, mobile interior repair',
    panelColor: '#8B6842',
  },
  {
    title: 'Avionics Support',
    sub: 'Troubleshoot, diagnose and maintain critical flight systems',
    href: '/services#avionics',
    img: '/images/heros/home-hero-3.webp',
    imgAlt: 'Avionics panel in a private jet cockpit, JetAvenue avionics diagnostics and support',
    panelColor: '#2A3A52',
  },
];
---

<BaseLayout
  title="JetAvenue: Mobile Private Jet Maintenance & Repair"
  description="FAA-certified mobile jet maintenance. Line & scheduled MX, interior repair, avionics support. We travel to your aircraft at VNY, SDL, or anywhere in the US."
  canonicalPath="/"
>

  <div class="welcome-strip">
    <span>WELCOME TO JET AVENUE</span>
  </div>

  <ServiceSlider slides={slides} />
  <FleetCards items={fleetItems} />
  <FAQ items={faqItems} />
  <CtaStrip />

</BaseLayout>

<style>
  .welcome-strip {
    background: var(--color-surface);
    text-align: center;
    padding: 18px var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }
  .welcome-strip span {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.22em;
    color: var(--color-body);
    text-transform: uppercase;
  }
</style>
