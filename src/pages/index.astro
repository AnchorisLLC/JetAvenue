---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceSlider from '../components/ServiceSlider.astro';
import FAQ from '../components/FAQ.astro';
import FleetCards from '../components/FleetCards.astro';

const fleetItems = [
  {
    name: 'Gulfstream',
    models: 'GIV · G450 · GV · G550 · G650 · G500 · G600',
    img: '/images/fleet/gulfstream-logo.svg',
    imgAlt: 'Gulfstream private jet on the ramp',
    logo: '/images/fleet/gulfstream-logo.svg',
  },
  {
    name: 'Bombardier',
    models: 'Challenger 300 · 350 · 3500 · 604 · 605 · 650 · Global Express · XRS · 5000 · 6000 · 7500 · CRJ 800',
    img: '/images/fleet/bombardier-logo.svg',
    imgAlt: 'Bombardier Challenger private jet',
    logo: '/images/fleet/bombardier-logo.svg',
  },
  {
    name: 'Dassault',
    models: 'DA50 · Falcon 900 · 2000 · 2000 EX EASY · 7X',
    img: '/images/fleet/dassault-logo.svg',
    imgAlt: 'Dassault Falcon private jet',
    logo: '/images/fleet/dassault-logo.svg',
  },
  {
    name: 'Embraer',
    models: 'ERJ135 · ERJ145 · Legacy 600 · Legacy 650 · E-Jet 190',
    img: '/images/fleet/embraer-logo.svg',
    imgAlt: 'Embraer Legacy private jet',
    logo: '/images/fleet/embraer-logo.svg',
  },
  {
    name: 'Cessna',
    models: 'Citation 560XL · 560XLS · CIT X · 680 · 680A',
    img: '/images/fleet/cessna-logo.svg',
    imgAlt: 'Cessna Citation private jet',
    logo: '/images/fleet/cessna-logo.svg',
  },
];

const faqItems = [
  {
    q: 'Do you come to our aircraft, or do we need to fly it to a facility?',
    a: 'We come to you. Our technicians travel to your aircraft at your home base, FBO, or wherever it\'s parked — no ferry flights, no repositioning costs.',
  },
  {
    q: 'What aircraft do you service?',
    a: 'Gulfstream (GIV–G650), Bombardier Challenger and Global series, Dassault Falcon, Embraer Legacy, and Cessna Citation. If your aircraft isn\'t listed, call us — we likely support it.',
  },
  {
    q: 'Where are you based?',
    a: 'Our primary bases are Van Nuys (VNY) and Scottsdale (SDL), but we travel nationwide. Wherever your aircraft is, we can get there.',
  },
  {
    q: 'What types of maintenance do you perform?',
    a: 'Line and scheduled maintenance, MEL clearing, borescopes, Pitot Static/91.411/91.413 checks, avionics diagnostics, mobile interior repair, and cleaning — all levels.',
  },
  {
    q: 'Are your technicians FAA-certified?',
    a: 'Yes. Our team holds Part 65 privileges with 200+ years of combined maintenance experience across business aviation.',
  },
  {
    q: 'How do I get started?',
    a: 'Call (844) 480-5387 or fill out the contact form for a free assessment. We\'ll discuss your aircraft, location, and service needs and get back to you within one business day.',
  },
];

const slides = [
  {
    title: 'Line & Scheduled Maintenance',
    sub: '24/7 on-call aircraft support to keep operations moving',
    href: '/#line-maintenance',
    img: '/images/heros/home-hero-1.jpg',
    imgAlt: 'Private jet on the ramp',
    panelColor: '#3A5A8C',
  },
  {
    title: 'Interior Cleaning & Repair',
    sub: 'On-site cabin interior repairs without downtime',
    href: '/#interior',
    img: '/images/heros/home-hero-2.webp',
    imgAlt: 'Technician repairing leather seating in private jet cabin',
    panelColor: '#8B6842',
  },
  {
    title: 'Avionics Support',
    sub: 'Troubleshoot, diagnose and maintain critical flight systems',
    href: '/#avionics',
    img: '/images/heros/home-hero-3.webp',
    imgAlt: 'Avionics panel in a private jet cockpit',
    panelColor: '#2A3A52',
  },
];
---

<BaseLayout title="JetAvenue — Mobile Private Jet Maintenance" description="Professional, quality, reliable mobile aircraft maintenance. We come to you — Los Angeles, Arizona, and nationwide.">

  <div class="welcome-strip">
    <span>WELCOME TO JET AVENUE</span>
  </div>

  <ServiceSlider slides={slides} />
  <FleetCards items={fleetItems} />
  <FAQ items={faqItems} />

</BaseLayout>

<style>
  .welcome-strip {
    background: var(--color-surface);
    text-align: center;
    padding: 18px var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }
  .welcome-strip span {
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.22em;
    color: var(--color-body);
    text-transform: uppercase;
  }
</style>
